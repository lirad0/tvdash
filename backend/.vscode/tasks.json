{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Backend: Spring Boot",
      "type": "shell",
      "command": "mvn spring-boot:run -Dspring-boot.run.arguments=--server.port=8081",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Backend: Spring Boot (Debug)",
      "type": "shell",
      "command": "mvn spring-boot:run -Dspring-boot.run.jvmArguments=\"-agentlib:jdwp=transport=dt_socket,server=y,suspend=y,address=5005\" -Dspring-boot.run.arguments=--server.port=8081",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true
      }
    },
    {
      "label": "Backend: Docker (Debug)",
      "type": "shell",
      "command": "DEBUG=true docker compose up",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true
      }
    }
  ]
}
